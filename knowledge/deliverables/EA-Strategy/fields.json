    "decisions": [
      {
        "id": "DD-1",
        "topic": "strategic_goals + kpi_alignment separation",
        "decision": "Keep as two separate top-level containers. strategic_goals owns goals→KPIs nesting; kpi_alignment owns cross-strategy KPI linkage matrix.",
        "applies_to": "this deliverable"
      },
      {
        "id": "DD-2",
        "topic": "focus_areas axis taxonomy",
        "decision": "Three axis types are sufficient: core_capability_axes, supporting_capability_axes, national_indicator_axes.",
        "applies_to": "this deliverable",
        "v0_2_revision_note": "DD-2 revised by DD-11: a fourth axis type (architecture_domain_axes) added in v0.2 based on practice-establishment p.52."
      },
      {
        "id": "DD-3",
        "topic": "governance container placement",
        "decision": "Keep governance as its own top-level container, not nested under metadata.",
        "applies_to": "all deliverables (project convention)"
      },
      {
        "id": "DD-4",
        "topic": "field key naming convention",
        "decision": "All field/container keys use snake_case English; every leaf and container carries name_ar with the original Arabic label.",
        "applies_to": "all deliverables (project convention)"
      }
    ]
  },
  "design_decisions_v0_2": {
    "approved_at": "2026-04-29",
    "approved_by": "Zidan (RMG Consulting)",
    "synthesis_inputs": [
      "practice-establishment p.10-22 (chapter 5.1: EA-Strategy definition)",
      "practice-establishment p.27-34 (chapter 5.4-5.5: organizational placement + governance)",
      "practice-establishment p.52-53 (procedures 10-17: domains + maturity)",
      "national-methodology-v1 p.114-143 — checked, content is business architecture implementation, NOT EA-Strategy fields, intentionally skipped"
    ],
    "decisions": [
      {
        "id": "DD-5",
        "topic": "success_factors as 6th identity element",
        "decision": "Add success_factors to identity. Justified by البيت الإستراتيجي (strategic house) on practice-establishment p.13 5.1.2.6 explicitly listing 5 components ending with عوامل النجاح.",
        "applies_to": "this deliverable"
      },
      {
        "id": "DD-6",
        "topic": "document_purpose_statement placement",
        "decision": "The 3 stated غايات (purposes) of EA strategy definition belong in metadata (not identity) as document_purpose_statement, since they describe why-the-document-exists rather than the entity's strategic content.",
        "applies_to": "this deliverable",
        "user_choice": "Gate 1 — chose metadata over identity over reject"
      },
      {
        "id": "DD-7",
        "topic": "current_state_assessment as object with 3 sub-tasks",
        "decision": "current_state_assessment is a structured object with document_review + stakeholder_meetings + swot_analysis. Each sub-task has its own evidence quote from p.11.",
        "applies_to": "this deliverable"
      },
      {
        "id": "DD-8",
        "topic": "benchmark_study marked optional",
        "decision": "Practice-establishment p.12 explicitly marks دراسة المقارنة المعيارية as اختيارية. Schema preserves this with optional_per_guide: true and study_status enum allowing 'not_conducted'.",
        "applies_to": "this deliverable"
      },
      {
        "id": "DD-9",
        "topic": "strategic_direction_analysis kept separate from strategic_alignment",
        "decision": "strategic_direction_analysis is a preparatory step (input documents review) that feeds the alignment work. Not merged into strategic_alignment because the latter holds the final intersection matrix; the former holds the analysis trail.",
        "applies_to": "this deliverable",
        "user_choice": "Gate 2 — chose 'add as separate field'"
      },
      {
        "id": "DD-10",
        "topic": "alignment_with_national_frameworks issuer enum is extensible",
        "decision": "framework_issuer is an enum starting with DGA + NCA + NDMO (per user input on KSA quasi-regulatory bodies). Marked extensible: true with a note for future additions.",
        "applies_to": "this deliverable",
        "user_input": "Gate 3 — user noted: هيئة الأمن السيبراني ومكتب إدارة البيانات الوطني بالإضافة إلى هيئة الحكومة الرقمية"
      },
      {
        "id": "DD-11",
        "topic": "architecture_domain_axes added as 4th sub-container in focus_areas",
        "decision": "The 6 NORA architecture domains (business/experience/applications/data/technical/security) are an orthogonal focus dimension to capability/national-indicator axes. Domain enum + Arabic value_map preserves bilingual integrity.",
        "applies_to": "this deliverable",
        "revises": "DD-2"
      },
      {
        "id": "DD-12",
        "topic": "governance_focus_axes added (4 governance axes)",
        "decision": "The 4 axes from p.33 5.5.3.2 (strategic_alignment_and_change, risk_management, expenditure_management, conflict_and_escalation) are encoded as enum + value_map. Each can be assigned to a responsible_committee.",
        "applies_to": "this deliverable"
      },
      {
        "id": "DD-13",
        "topic": "stakeholder_engagement added as 8th top-level container",
        "decision": "Despite being process-evidence rather than strategic content, stakeholder workshops are explicit in p.13 5.1.2.6 with a recommended agenda. Promoting to its own container keeps governance focused on approval and preserves audit trail of who shaped the strategy.",
        "applies_to": "this deliverable",
        "user_choice": "Gate 6 — chose 'new container' over 'merge into governance' over 'reject'"
      },
      {
        "id": "DD-14",
        "topic": "rejected candidates and rationale",
        "decision": "5 candidates explicitly rejected as out-of-scope for EA-Strategy document; documented here for audit trail.",
        "applies_to": "this deliverable",
        "rejected": [
          {
            "candidate": "strategic_house_diagram_ref",
            "rationale": "Reference to a derived view (Figure 5). The components (vision/mission/pillars/goals/success_factors) are already individual fields in identity; the diagram is a presentation artifact, not data."
          },
          {
            "candidate": "gap_identification_and_reuse",
            "rationale": "Out of scope — belongs to EA-Roadmap (DEL-DOC-005) or Gap Analysis report (DEL-RPT). EA-Strategy declares direction; gap analysis evaluates current vs target."
          },
          {
            "candidate": "service_delivery_areas",
            "rationale": "Out of scope — describes services delivered by the EA practice itself (what the EA unit produces). Belongs to EA-Operating-Model deliverable."
          },
          {
            "candidate": "organizational_structure_placement",
            "rationale": "Out of scope per user decision (Gate 5) — placement model (Strategy-focused vs IT-focused) and sponsor role belong to EA-Operating-Model. Governance container in EA-Strategy stays focused on approval flow."
          },
          {
            "candidate": "maturity_assessment_procedures",
            "rationale": "Out of scope — operational procedure that belongs to a dedicated EA-Maturity-Assessment deliverable. Medium confidence in source text also weakened the case."
          }
        ]
      },
      {
        "id": "DD-15",
        "topic": "kpi_alignment intentionally unchanged in v0.2",
        "decision": "Subagent found no justified additions in the read ranges. National-methodology p.114-143 (chapter on initiative evaluation) referenced KPIs but only in OPEX/CAPEX initiative-prioritization context, not in cross-strategy KPI alignment. Re-evaluate when D-phase deliverable schemas surface KPI-related dependencies.",
        "applies_to": "this deliverable"
      }
    ]
  }
